@model WardDapperMVC.Models.Domain.Bed
@{
    ViewData["Title"] = "EditBed";
}

<div class="wide-dark-box">
    <h2 class="text-center">UPDATE BEDS</h2>
    <br />
    <p>
        Welcome to the Manage Wards/Beds section of our Ward Management System.
        This feature is designed to help administrators efficiently manage and optimize the allocation of wards and beds within our healthcare facility.
    </p>

    <form asp-action="EditBed" method="post">
        <input type="hidden" asp-for="BedID" />

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="BedNo" class="form-label">Bed Number<span style="color: red;">*</span></label>
                <input asp-for="BedNo" type="text" class="form-control">
                <span class="text-danger" asp-validation-for="BedNo"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="WardId" class="form-label">Ward<span style="color: red;">*</span></label>
                @* Use ViewBag to populate the dropdown list *@
                @Html.DropDownListFor(model => model.WardId, ViewBag.WardList as SelectList, "_Select Ward_", new { @class = "form-control" })
                <span class="text-danger" asp-validation-for="WardId"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="BedAvailabilityStatus" class="form-label">Bed Availability Status<span style="color: red;">*</span></label>
                <select asp-for="BedAvailabilityStatus" class="form-control">
                    <option value="Available">Available</option>
                    <option value="Not Available">Not Available</option>
                </select>
                <span class="text-danger" asp-validation-for="BedAvailabilityStatus"></span>
            </div>
        </div>

        <br />
        @if (TempData["msg"] != null)
        {
            <div id="notification" class="mb-3 alert alert-info">
                @TempData["msg"]
            </div>
        }

        <div class="d-flex justify-content-start align-items-center">
            <button type="submit" class="btn btn-success">Save</button>
            <span class="mx-2" style="border-right: 2px solid white; height: 24px;"></span>
            <a asp-controller="Bed" asp-action="DisplayAllBed" class="my-2 btn btn-primary">Display Records</a>
        </div>

    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Hide validation messages when user starts typing
            $('input, textarea').on('input', function () {
                $(this).siblings('.text-danger').hide();
            });
        });
        $(document).ready(function () {
            // Show notification if it exists
            if ($('#notification').text().trim() !== '') {
                $('#notification').fadeIn().delay(3000).fadeOut(); // Display for 3 seconds
            }
        });
    </script>
}