@model IEnumerable<WardDapperMVC.Models.Domain.Bed>
@{
    ViewData["Title"] = "DisplayAllBed";
}

<div class="wide-dark-box">
    <h1 class="text-center">MANAGE BEDS</h1>
    <br />
    <p>
        Welcome to the Manage Wards/Beds section of our Ward Management System.
        This feature is designed to help administrators efficiently manage and optimize the allocation of wards and beds within our healthcare facility.
    </p>

    <div class="table-responsive">
        <table class="table table-bordered">
            <!-- Search Form -->
            <form method="get" asp-controller="Bed" asp-action="DisplayAllBed" class="mb-3">
                <div class="input-group">
                    <input type="text" name="search" class="form-control" placeholder="Search by Bed Number"
                           aria-label="Search by Patient Number" value="@Context.Request.Query["search"]" style="max-width: 300px;" />
                    <button class="btn btn-outline-secondary" type="submit">Search</button>
                </div>
            </form>
            <thead class="table-dark">
                <tr>
                    <th>Bed Number</th>
                    <th>Ward Name</th>
                    <th>Available Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-light">
                @foreach (var bed in Model)
                {
                    <tr>
                        <td>@bed.BedNo</td>
                        <td>@bed.WardName</td> <!-- Display Ward Name -->
                        <td>@bed.BedAvailabilityStatus</td>
                        <td white-space: nowrap>
                            <a asp-controller="Bed" asp-action="EditBed" asp-route-id="@bed.BedID" class="btn btn-info my-2">Edit</a>
                            <a asp-controller="Bed" asp-action="DeleteBed" asp-route-id="@bed.BedID" class="btn btn-danger" onclick="return window.confirm('Are you sure you want to delete this record? This action cannot be undone.')">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <br />
    <a asp-controller="Bed" asp-action="AddBed" class="btn btn-success">Add more</a>
    <span class="mx-2" style="border-right: 2px solid white; height: 24px;"></span>
    <a asp-controller="Ward" asp-action="DisplayAllWard" class="my-2 btn btn-primary">Back</a>
    <br />
    <div id="notification" style="display:none; padding: 10px;">
        @if (TempData["msg"] != null)
        {
            <div class="mb-3 alert alert-info">
                @TempData["msg"]
            </div>
        }
    </div>
</div>

<style>
    /* Search bar styling */
    .input-group {
        max-width: 290px; /* Set a max width for the search bar */
        margin-bottom: 20px; /* Add margin below the search bar */
    }

    /* Highlight row on hover */
    .table tbody tr:hover {
        background-color: #f1f1f1; /* Light gray background */
    }

    /* Optional: Make the table more visually appealing */
    .table {
        margin-top: 20px;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Show notification if it exists
            if ($('#notification').text().trim() !== '') {
                $('#notification').fadeIn().delay(3000).fadeOut(); // Display for 3 seconds
            }
        });
    </script>
}




