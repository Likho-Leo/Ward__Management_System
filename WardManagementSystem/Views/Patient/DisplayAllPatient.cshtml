@model IEnumerable<WardDapperMVC.Models.Domain.Patient>
@{
    ViewData["Title"] = "DisplayAll";
}

<div class="wide-dark-box">
    <h1 class="text-center">MANAGE PATIENTS</h1>
    <br />
    <p>
        Welcome to our patient management system.
        Begin by admitting new patients, updating their information, and finalizing the discharge process. For any assistance, our team is here to help.
    </p>

    <div class="table-responsive">
        <!-- Search Form -->
        <form method="get" asp-action="DisplayAllPatient" class="mb-3">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Search by Patient Number" 
                       aria-label="Search by Patient Number" value="@Context.Request.Query["search"]" style="max-width: 300px;" />
                <button class="btn btn-outline-secondary" type="submit">Search</button>
            </div>
        </form>

        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Patient Number</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Title</th>
                    <th>Gender</th>
                    <th>Date Of Birth</th>
                    <th>ID Number</th>
                    <th>Email</th>
                    <th>Phone Number</th>
                    <th>AddressLine1</th>
                    <th>AddressLine2</th>
                    <th>Country</th>
                    <th>Province</th>
                    <th>City</th>
                    <th>Town/Surburb</th>
                    <th>Postal Code</th>
                    <th>Next Of Kin FullName</th>
                    <th>Next Of Kin Relationship</th>
                    <th>Next Of Kin Phone Number</th>
                    <th>EmergencyContactName</th>
                    <th>EmergencyContactPhone</th>
                    <th>Insurance Provider</th>
                    <th>Policy Number</th>
                    <th>Medical History</th>
                    <th>Allergies</th>
                    <th>Current Medications</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-light">
                @foreach (var patient in Model)
                {
                    <tr>
                        <td>@patient.PatientNumber</td>
                        <td>@patient.FirstName</td>
                        <td>@patient.LastName</td>
                        <td>@patient.Title</td>
                        <td>@patient.Gender</td>
                        <td>@patient.DOB.ToString("yyyy-MM-dd")</td>
                        <td>@patient.IDNumber</td>
                        <td>@patient.Email</td>
                        <td>@patient.PhoneNumber</td>
                        <td>@patient.AddressLine1</td>
                        <td>@patient.AddressLine2</td>
                        <td>@patient.Country</td>
                        <td>@patient.Province</td>
                        <td>@patient.City</td>
                        <td>@patient.Town_Surburb</td>
                        <td>@patient.PostalCode</td>
                        <td>@patient.NextOfKinName</td>
                        <td>@patient.NextOfKinRelationship</td>
                        <td>@patient.NextOfKinPhoneNumber</td>
                        <td>@patient.EmergencyContactName</td>
                        <td>@patient.EmergencyContactPhone</td>
                        <td>@patient.InsuranceProvider</td>
                        <td>@patient.PolicyNumber</td>
                        <td>@patient.MedicalHistory</td>
                        <td>@patient.Allergies</td>
                        <td>@patient.CurrentMedications</td>
                        <td white-space: nowrap>
                            <a asp-action="EditPatient" asp-controller="Patient" asp-route-id="@patient.PatientId" class="btn btn-info my-2">Edit</a>
                            <a asp-action="DeletePatient" asp-controller="Patient" asp-route-id="@patient.PatientId" class="btn btn-danger" onclick="return window.confirm('Are you sure you want to delete this record? This action cannot be undone.')">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <br />
    <a asp-action="DisplayNewRefers" class="btn btn-success">Admit New</a>
    <br />
    <div id="notification" style="display:none; padding: 10px;">
        @if (TempData["msg"] != null)
        {
            <div class="mb-3 alert alert-info">
                @TempData["msg"]
            </div>
        }
    </div>
</div>

<style>
    /* Search bar styling */
    .input-group {
        max-width: 300px; /* Set a max width for the search bar */
        margin-bottom: 20px; /* Add margin below the search bar */
    }

    /* Highlight row on hover */
    .table tbody tr:hover {
        background-color: #f1f1f1; /* Light gray background */
    }

    /* Optional: Make the table more visually appealing */
    .table {
        margin-top: 20px;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Show notification if it exists
            if ($('#notification').text().trim() !== '') {
                $('#notification').fadeIn().delay(3000).fadeOut(); // Display for 3 seconds
            }
        });
    </script>
}





