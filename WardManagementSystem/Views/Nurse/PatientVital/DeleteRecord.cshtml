@using WardDapperMVC.Models.Domain.Nurse
@model PatientVital
@{
    ViewData["Title"] = "Delete Patient Vitals";
}

<div class="wide-dark-box">
    <h1 class="text-center">Delete Confirmation</h1>
    <hr style="border: 1px solid white; width: 100%; text-align: center;" />
    <p >Are you sure you want to delete this record?</p>
    <br />
    <form method="post" asp-action="DeleteVital" asp-controller="PatientVital">
        <div class="form-group">
            <input type="hidden" name="id" value="@Model.VitalId" />
            <input type="hidden" name="id" value="@Model.PatientId" />
            <div class="row">
                @* Patient First Name and Body Temperature *@
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.PatientFirstName)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.PatientFirstName)
                        </dd>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.BodyTemp)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.BodyTemp)
                        </dd>
                    </div>
                </div>
            </div>

            <div class="row">
                @* Patient Last Name and Body Weight *@
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.PatientLastName)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.PatientLastName)
                        </dd>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.Weight)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.Weight)
                        </dd>
                    </div>
                </div>
            </div>

            <div class="row">
                @* Blood Pressure and Date *@
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.BloodPressure) 
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.BloodPressure)
                        </dd>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            Date
                        </dt>
                        <dd class="col-sm-6">
                            @Model.Date.ToString("dd/MM/yyyy")
                        </dd>
                    </div>
                </div>
            </div>

            <div class="row">
                @* Blood Oxygen Level and Nurse First Name *@
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.BloodOxygen) 
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.BloodOxygen)
                        </dd>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.NurseFirstName)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.NurseFirstName)
                        </dd>
                    </div>
                </div>
            </div>

            <div class="row">
                @* Blood Glucose Level and Nurse Last Name *@
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.BloodGlucoseLvl)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.BloodGlucoseLvl)
                        </dd>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.NurseLastName)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.NurseLastName)
                        </dd>
                    </div>
                </div>
            </div>

            <div class="row">
                @* Pulse Rate and Respiration Rate *@
                <div class="col-sm-6">
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.PulseRate)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.PulseRate)
                        </dd>
                    </div>
                    <div class="row">
                        <dt class="col-sm-6">
                            @Html.DisplayNameFor(model => model.RespirationRate)
                        </dt>
                        <dd class="col-sm-6">
                            @Html.DisplayFor(model => model.RespirationRate)
                        </dd>
                    </div>
                </div>
            </div>
        <br />    
    </form>
    <form method="post" asp-action="DeleteVital" asp-route-id="@Model.VitalId">
        <button type="submit" class="btn btn-danger">Delete</button>
        <span class="mx-2" style="border-right: 2px solid white; height: 24px;"></span>
        <a href="@Url.Action("DisplayAll")" class="btn btn-success">Cancel</a>
    </form>
</div>