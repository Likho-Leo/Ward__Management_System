@using WardDapperMVC.Models.Domain.Nurse
@using System.Security.Claims
@model MedAdministration

@{
    ViewData["Title"] = "Update administration of none-sheduled medication";
}
<div class="wide-dark-box">
    <h3 class="text-center">ADMINISTER MEDICATION</h3>
    <hr style="border: 1px solid white; width: 100%; text-align: center;" />
    <p class="text-center">
        Welcome to the Administer Medication section of our Ward Management System. This feature is designed to facilitate the accurate recording medications administered to patients under your care.
    </p>

    <form asp-action="UpdateRecord">
        <input asp-for="AdminMedID" id="AdminMedID" type="text" class="form-control" hidden>
        <input asp-for="PatientId" id="PatientId" type="text" class="form-control" hidden>
        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="PatientNumber" class="form-label">Patient Number<span style="color: red;">*</span></label>
                <input asp-for="PatientNumber" id="PatientNo" type="text" class="form-control"readonly>
                <span class="text-danger" asp-validation-for="PatientNumber"></span>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-4">
                <label asp-for="PatientFirstName" class="form-label">Patient First Name<span style="color: red;">*</span></label>
                <input asp-for="PatientFirstName" id="PatientFirstName" type="text" class="form-control" readonly>
                <span class="text-danger" asp-validation-for="PatientFirstName"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="PatientLastName" class="form-label">Patient Last Name<span style="color: red;">*</span></label>
                <input asp-for="PatientLastName" id="PatientLastName" type="text" class="form-control"readonly>
                <span class="text-danger" asp-validation-for="PatientLastName"></span>
            </div>
        </div>

        <input asp-for="UserId" id="UserId" type="text" class="form-control" hidden>

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="EmployeeNumber" class="form-label">Employee Number<span style="color: red;">*</span></label>
                <input asp-for="EmployeeNumber" id="EmployeeNo" type="text" class="form-control"readonly>
                <span class="text-danger" asp-validation-for="EmployeeNumber"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="NurseFirstName" class="form-label">Nurse First Name<span style="color: red;">*</span></label>
                <input asp-for="NurseFirstName" type="text" class="form-control" readonly>
                <span class="text-danger" asp-validation-for="NurseLastName"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="NurseLastName" class="form-label">Nurse Last Name<span style="color: red;">*</span></label>
                <input asp-for="NurseLastName" type="text" class="form-control" readonly>
                <span class="text-danger" asp-validation-for="NurseLastName"></span>
            </div>
        </div>
        <br />
        <div class="col-md-4">
            <label asp-for="Med" class="form-label">Medication Name<span style="color: red;">*</span></label>
            <textarea class="form-control" asp-for="Med" rows="3" placeholder="Enter medication name, dosage, route and frequency"></textarea>
            <span class="text-danger" asp-validation-for="Med"></span>
        </div>

        @{
            var userRole = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
            if (userRole == "NursingSister")
            {
                <div class="col-md-4">
                    <label asp-for="status" class="form-label">Type</label>
                    <select asp-for="status" class="form-control input-long">
                        <option value="">Select medication type</option>
                        <option value="Scheduled">Scheduled</option>
                        <option value="Non-Scheduled">Non-Scheduled</option>
                    </select>
                    <span class="text-danger" asp-validation-for="status"></span>
                </div>
            }
            else
            {
                <div class="col-md-4">
                    <label asp-for="status" class="form-label">Status<span style="color: red;">*</span></label>
                    <input asp-for="status" type="text" class="form-control" value="Non-Scheduled" readonly>
                    <span class="text-danger" asp-validation-for="status"></span>
                </div>
            }
        }

        <div class="col-md-4">
            <label asp-for="Date" class="form-label">Date and Time<span style="color: red;">*</span></label>
            <input asp-for="Date" type="datetime-local" class="form-control" placeholder="Required" step="60">
            <span class="text-danger" asp-validation-for="Date"></span>
        </div>

        <br />

        @if (TempData["msg"] != null)
        {
            <div class="alert alert-info">
                @TempData["msg"]
            </div>
        }

        <div class="d-flex justify-content-start align-items-center">
            <button type="submit" class="btn btn-success "> Update </button>
            <span class="mx-2" style="border-right: 2px solid #000; height: 24px;"></span>
            <a href="~/MedAdministration/DisplayAllRecords" class="btn btn-primary">View All Records</a>
        </div>
        <br />
    </form>
</div>
