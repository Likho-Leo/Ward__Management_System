@model IEnumerable<WardDapperMVC.Models.Domain.Medication>
@{
    ViewData["Title"] = "DisplayAllMed";
}

<div class="wide-dark-box">
    <h1 class="text-center">MANAGE MEDICATIONS</h1>
    <br />
    <p>
        Welcome to the Manage Medication section of our Ward Management System.
        This feature is designed to help administrators and healthcare professionals efficiently manage and monitor patient medications.
    </p>

    <div class="table-responsive">
        <!-- Search Form -->
        <form method="get" asp-controller="Medication" asp-action="DisplayAllMed" class="mb-3">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Search by Medication Name"
                       aria-label="Search by Patient Number" value="@Context.Request.Query["search"]" style="max-width: 300px;" />
                <button class="btn btn-outline-secondary" type="submit">Search</button>
            </div>
        </form>
        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Medication Type</th>
                    <th>Medication Name</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-light">
                @foreach (var medication in Model)
                {
                    <tr>
                        <td>@medication.MedicationType</td>
                        <td>@medication.MedicationName</td>
                        <td>@medication.Description</td>
                        <td white-space: nowrap>
                            <a asp-controller="Medication" asp-action="EditMed" asp-route-id="@medication.MedID" class="btn btn-info my-2">Edit</a>
                            <a asp-controller="Medication" asp-action="DeleteMed" asp-route-id="@medication.MedID" class="btn btn-danger" onclick="return window.confirm('Are you sure you want to delete this record? This action cannot be undone.')">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <br />
    <a asp-controller="Medication" asp-action="AddMed" class="btn btn-success">Add more</a>
    <br />
    <div id="notification" style="display:none; padding: 10px;">
        @if (TempData["msg"] != null)
        {
            <div class="mb-3 alert alert-info">
                @TempData["msg"]
            </div>
        }
    </div>
</div>

<style>
    /* Search bar styling */
    .input-group {
        max-width: 320px; /* Set a max width for the search bar */
        margin-bottom: 20px; /* Add margin below the search bar */
    }

    /* Highlight row on hover */
    .table tbody tr:hover {
        background-color: #f1f1f1; /* Light gray background */
    }

    /* Optional: Make the table more visually appealing */
    .table {
        margin-top: 20px;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Show notification if it exists
            if ($('#notification').text().trim() !== '') {
                $('#notification').fadeIn().delay(3000).fadeOut(); // Display for 3 seconds
            }
        });
    </script>
}