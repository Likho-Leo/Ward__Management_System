@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WardManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WardManagementSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="icon" type="image/x-icon" href="~/Images/favicon.png">
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                <img src="~/Images/logo.png" alt="Ward Management System Logo" width="50" height="50">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
                <div class="d-flex flex-grow-1 align-items-center">
                    <div class="navbar-nav me-auto">
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                            <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                            <a class="nav-link" asp-controller="Home" asp-action="FAQ">FAQ</a>
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            
                        }
                        @if (User.Identity.IsAuthenticated)
                        {
                            var userRole = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
                            var userName = User.Identity.Name; // Get the user's name

                            if (userRole == "WardAdmin")
                            {
                                <a class="nav-link" asp-controller="WardAdmin" asp-action="Home">Home</a>
                                <a class="nav-link position-relative" asp-controller="Patient" asp-action="DisplayNewRefers">
                                    Pending Admissions
                                    @if (ViewData["NewReferralCount"] != null && (int)ViewData["NewReferralCount"] > 0)
                                    {
                                        <span class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-circle">
                                            @ViewData["NewReferralCount"]
                                        </span>
                                    }
                                </a>
                                <a class="nav-link" asp-controller="SearchPatient" asp-action="Search">Reports</a>
                            }
                            if (userRole == "Admin")
                            {
                                <a class="nav-link" asp-controller="Admin" asp-action="Home">Home</a>
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Statistics</a>
                                <a class="nav-link" asp-controller="EmployeeSearch" asp-action="EmployeeSearch">Reports</a>
                            }
                            if (userRole == "Doctor")
                            {
                                <a class="nav-link" asp-controller="Doctor" asp-action="Home">Home</a>
                            }
                            if (userRole == "Nurse")
                            {
                                <a class="nav-link" asp-controller="Nurse" asp-action="Home">Home</a>
                                <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                                <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact Us</a>
                                <a class="nav-link" asp-controller="Home" asp-action="FAQ">FAQ</a>
                                <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            }
                            if (userRole == "NursingSister")
                            {
                                <a class="nav-link" asp-controller="Nurse" asp-action="Home">Home</a>
                                <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                                <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact Us</a>
                                <a class="nav-link" asp-controller="Home" asp-action="FAQ">FAQ</a>
                                <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            }
                            if (userRole == "StockManager")
                            {
                                <a class="nav-link" asp-controller="StockManager" asp-action="Index">Home</a>
                            }
                            if (userRole == "ScriptManager")
                            {
                                <a class="nav-link" asp-controller="ScriptManager" asp-action="Home">Home</a>
                            }
                        }
                    </div>

                    <div class="d-flex align-items-center ms-auto">

                        @if (User.Identity.IsAuthenticated)
                        {
                            var userRole = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
                            var userName = User.Identity.Name;

                            <span class="navbar-text text-light me-3 d-flex align-items-center">
                                <span>
                                    @User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value:<br>
                                    @User.Identity.Name
                                </span>
                                @if (userRole == "WardAdmin")
                                {
                                    <img src="@Url.Content("~/Images/Shared/user.svg")" alt="User Icon" class="img-fluid me-2">
                                }
                                @if (userRole == "Admin")
                                {
                                    <img src="@Url.Content("~/Images/Shared/admin.png")" alt="User Icon" class="img-fluid me-2">
                                }
                                @if (userRole == "Nurse")
                                {
                                    <img src="@Url.Content("~/Images/Shared/nurse.png")" alt="User Icon" class="img-fluid me-2">
                                }
                                @if (userRole == "Nursing Sister")
                                {
                                    <img src="@Url.Content("~/Images/Shared/nursingSister.png")" alt="User Icon" class="img-fluid me-2">
                                }
                                @if (userRole == "Doctor")
                                {
                                    <img src="@Url.Content("~/Images/Shared/doctor.png")" alt="User Icon" class="img-fluid me-2">
                                }
                            </span>

                            <form asp-controller="Login" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-light btn-sm" href="~/Login/Login">Login</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        <div class="container mt-4">
            @RenderBody()
        </div>
    </main>

    <footer>
        &copy; 2024 System for Healthcare Integration and Facility Tracking
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

