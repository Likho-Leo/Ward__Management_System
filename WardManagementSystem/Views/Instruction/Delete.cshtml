@model WardDapperMVC.Models.Domain.PatientInstruction

<div class="wide-dark-box">
    <h2>Delete Patient Instruction</h2>

    <h4>Are you sure you want to delete this instruction?</h4>
    <div>
        <h5>Instruction ID: @Model.InstructionID</h5>
        <p>Patient ID: @Model.PatientID</p>
        <p>User ID: @Model.DoctorID</p>
        <p>Date of Visit: @Model.DateOfVisit.ToShortDateString()</p>
        <p>Follow Up Appointment Date: @Model.FollowUpAppointmentDate?.ToShortDateString()</p>
        <!-- Display other fields if necessary -->
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="InstructionID" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="DisplayAll" class="btn btn-secondary">Cancel</a>
    </form>
</div>



