@model WardDapperMVC.Models.Domain.PatientReferrals

@{
    ViewData["Title"] = "Create Referral";
}

<div class="wide-dark-box">
    <h2>Create Referral</h2>
    <h4>Referral</h4>
    <hr />
    <div class="col-md-4">
        <label asp-for="EmployeeNumber" class="form-label">Employee Number<span class="text-danger">*</span></label>
        <div class="d-flex align-items-center">
            <input asp-for="EmployeeNumber" type="text" class="form-control me-2" placeholder="Enter Employee Number" style="flex: 1;" />
            <button type="button" class="btn btn-info" onclick="searchPatient()">Search</button>
        </div>
        @*  <span class="text-danger" asp-validation-for="PatientNumber"></span> *@
    </div>
    <br />
    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="UserID" readonly />

        <div class="row mb-3">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label asp-for="FirstName" class="form-label">Doctor FirstName<span style="color: red;">*</span></label>
                    <input asp-for="FirstName" type="text" class="form-control" readonly />
                </div>

                <div class="col-md-4">
                    <label asp-for="LastName" class="form-label">Doctor LastName<span style="color: red;">*</span></label>
                    <input asp-for="LastName" type="text" class="form-control" readonly />
                </div>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="PatientFirstName" class="form-label">Patient FirstName<span style="color: red;">*</span></label>
                <input asp-for="PatientFirstName" type="text" class="form-control"  />
            </div>

            <div class="col-md-4">
                <label asp-for="PatientLastName" class="form-label">Patient LastName<span style="color: red;">*</span></label>
                <input asp-for="PatientLastName" type="text" class="form-control" />
            </div>
        </div>     
        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="Date" class="form-label">Date<span style="color: red;">*</span></label>
                <input asp-for="Date" type="date" class="form-control" />
                <span class="text-danger" asp-validation-for="Date"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Status" class="form-label">Status<span style="color: red;">*</span></label>
                <select asp-for="Status" class="form-control">
                    <option value="">Select Status</option>
                    <option value="Refer">Refer</option>
                    @* <option value="Discharge">Discharge</option> *@
                </select>
                <span class="text-danger" asp-validation-for="Status"></span>
            </div>
        </div>

        <br />
        @if (TempData["msg"] != null)
        {
            <div class="mb-3 alert alert-info">
                @TempData["msg"]
            </div>
        }

        <div class="d-flex justify-content-start align-items-center">
            <button type="submit" class="btn btn-success">Save</button>
            <span class="mx-2" style="border-right: 2px solid white; height: 24px;"></span>
            <a asp-action="DisplayAll" class="my-2 btn btn-primary">Display Records</a>
        </div>

    </form>
</div>


@* This is JS for Searching using EmployeeNumber *@
@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>

        function searchPatient() {
            var employeeNumber = $('#EmployeeNumber').val().trim();
            // Validate the format (assuming valid format starts with "PAT" and is followed by digits)
            var regex = /^Emp\d+$/; // Matches "PAT" followed by one or more digits

            if (employeeNumber && regex.test(employeeNumber)) {
                $.ajax({
                    url: '@Url.Action("GetEmployeeByNumber", "Referrals")',
                    type: 'GET',
                    data: { employeeNumber: employeeNumber },
                    success: function (data) {
                        if (data) {
                            $('#FirstName').val(data.firstName);
                            $('#LastName').val(data.lastName);
                            $('#UserID').val(data.userID);
                        } else {
                            alert('Employee not found');
                        }
                    },
                    error: function () {
                        alert('Error retrieving employee information');
                    }
                });
            } else {
                alert('Please enter a valid Employee Number (e.g., Emp01,Emp100)');
            }
        }

        $(document).ready(function () {
            // Hide validation messages when user starts typing
            $('input, textarea').on('input', function () {
                $(this).siblings('.text-danger').hide();
            });
        });

    </script>
}


