@model WardDapperMVC.Models.Domain.Prescription
<div class="wide-dark-box">
    <h2>Delete Prescription</h2>
    <h4>Are you sure you want to delete this?</h4>
    <div>
        <h4>@Model.Script</h4> <!-- Display prescription details -->
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="PrescriptionID" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="DisplayAll" class="btn btn-secondary">Cancel</a>
    </form>
</div>

