@model WardDapperMVC.Models.Domain.Prescription

<div class="wide-dark-box">
    <h2>Prescription Details</h2>

    <div>
        <h4>Prescription</h4>
        <hr />
        <dl class="dl-horizontal">
            <dt>
                Doctor Name
            </dt>
            <dd>
                @Html.DisplayFor(model => model.DoctorFirstName) @Html.DisplayFor(model => model.DoctorLastName)
            </dd>
            <dt>
                Patient Name
            </dt>
            <dd>
                @Html.DisplayFor(model => model.FirstName) @Html.DisplayFor(model => model.LastName)
            </dd>
            <dt>
                Prescription
            </dt>
            <dd>
                @Html.DisplayFor(model => model.Script)
            </dd>
            <dt>
                Date
            </dt>
            <dd>
                @Html.DisplayFor(model => model.Date)
            </dd>
            <dt>
                Process Status
            </dt>
            <dd>
                @Html.DisplayFor(model => model.ProcessStatus)
            </dd>
            
           
        </dl>
    </div>
    <div class="d-flex justify-content-start align-items-center">
        <a asp-action="Edit" asp-route-id="@Model.PrescriptionID" class="btn btn-warning">Edit</a>
        <span class="mx-2" style="border-right: 2px solid white; height: 24px;"></span>
        <a asp-action="Delete" asp-route-id="@Model.PrescriptionID" class="btn btn-danger">Delete</a>
        <span class="mx-2" style="border-right: 2px solid white; height: 24px;"></span>
        <a asp-action="DisplayAll" class="my-2 btn btn-primary">Display Records</a>
    </div>
    @* <div>
        <a asp-action="Edit" asp-route-id="@Model.PrescriptionID">Edit</a> |
        <a asp-action="Delete" asp-route-id="@Model.PrescriptionID">Delete</a> |
        <a asp-action="DisplayAll">Back to List</a>
    </div> *@
</div>


