@model IEnumerable<WardDapperMVC.Models.Domain.User>
@{
    ViewData["Title"] = "DisplayAllUser";
}

<div class="wide-dark-box">
    <h1 class="text-center">MANAGE EMPLOYEES</h1>
    <br />
    <p>
        Welcome to the Manage Employees section of our Ward Management System. 
        This feature is designed to help administrators efficiently manage and oversee employee information and operations.
    </p>

    <div class="table-responsive">
        <!-- Search Form -->
        <form method="get" asp-action="DisplayAllUser" class="mb-3">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Search by Employee No"
                       aria-label="Search by Patient Number" value="@Context.Request.Query["search"]" style="max-width: 300px;" />
                <button class="btn btn-outline-secondary" type="submit">Search</button>
            </div>
        </form>
        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Employee Number</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Title</th>
                    <th>Gender</th>
                    <th>ID Number</th>
                    <th>Date Of Birth</th>
                    <th>Phone Number</th>
                    <th>Email</th>
                    <th>Password</th>
                    <th>AddressLine1</th>
                    <th>AddressLine2</th>
                    <th>Country</th>
                    <th>Province</th>
                    <th>City</th>
                    <th>Town/Surburb</th>
                    <th>Postal Code</th>
                    <th>Role</th>
                    <th>Employment Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-light">
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.EmployeeNumber</td>
                        <td>@user.FirstName</td>
                        <td>@user.LastName</td>
                        <td>@user.Title</td>
                        <td>@user.Gender</td>
                        <td>@user.IDNo</td>
                        <td>@user.DOB.ToString("yyyy-MM-dd")</td> <!-- Format DOB -->
                        <td>@user.PhoneNumber</td>
                        <td>@user.Email</td>
                        <td>******</td> <!-- Masked password -->
                        <td>@user.AddressLine1</td>
                        <td>@user.AddressLine2</td>
                        <td>@user.Country</td>
                        <td>@user.Province</td>
                        <td>@user.City</td>
                        <td>@user.Town_Surburb</td>
                        <td>@user.PostalCode</td>
                        <td>@user.Role</td>
                        <td>@user.EmploymentDate.ToString("yyyy-MM-dd")</td>
                        <td white-space: nowrap>
                            <a asp-controller="User" asp-action="EditUser" asp-route-id="@user.UserID" class="btn btn-info my-2">Edit</a>
                            <a asp-controller="User" asp-action="DeleteUser" asp-route-id="@user.UserID" class="btn btn-danger" onclick="return window.confirm('Are you sure you want to delete this record? This action cannot be undone.')">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
    <br />
    <a asp-controller="User" asp-action="AddUser" class="btn btn-success">Add more</a>
    <br />
    <div id="notification" style="display:none; padding: 10px;">
        @if (TempData["msg"] != null)
        {
            <div class="mb-3 alert alert-info">
                @TempData["msg"]
            </div>
        }
    </div>
</div>

<style>
    /* Search bar styling */
    .input-group {
        max-width: 300px; /* Set a max width for the search bar */
        margin-bottom: 20px; /* Add margin below the search bar */
    }

    /* Highlight row on hover */
    .table tbody tr:hover {
        background-color: #f1f1f1; /* Light gray background */
    }

    /* Optional: Make the table more visually appealing */
    .table {
        margin-top: 20px;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Show notification if it exists
            if ($('#notification').text().trim() !== '') {
                $('#notification').fadeIn().delay(3000).fadeOut(); // Display for 3 seconds
            }
        });
    </script>
}