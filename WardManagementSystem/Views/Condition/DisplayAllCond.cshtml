@model IEnumerable<WardDapperMVC.Models.Domain.Condition>
@{
    ViewData["Title"] = "DisplayAllCond";
}

<div class="wide-dark-box">
    <h1 class="text-center">MANAGE CONDITIONS</h1>
    <br />
    <p>
        Welcome to the Manage Conditions section of our Ward Management System.
        This feature is designed to assist administrators and healthcare professionals in accurately documenting and managing patient conditions.
    </p>
    <div class="table-responsive">
        <!-- Search Form -->
        <form method="get" asp-controller="Condition" asp-action="DisplayAllCond" class="mb-3">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Search by Condition"
                       aria-label="Search by Patient Number" value="@Context.Request.Query["search"]" style="max-width: 300px;" />
                <button class="btn btn-outline-secondary" type="submit">Search</button>
            </div>
        </form>
        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Condition</th>
                    <th>Condition Type</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-light">
                @foreach (var condition in Model)
                {
                    <tr>
                        <td>@condition.Conditions</td>
                        <td>@condition.ConditionType</td>
                        <td white-space: nowrap>
                            <a asp-controller="Condition" asp-action="EditCondition" asp-route-id="@condition.ConditionID" class="btn btn-info my-2">Edit</a>
                            <a asp-controller="Condition" asp-action="DeleteCondition" asp-route-id="@condition.ConditionID" class="btn btn-danger" onclick="return window.confirm('Are you sure you want to delete this record? This action cannot be undone.')">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
    <br />
    <a asp-controller="Condition" asp-action="AddCondition" class="btn btn-success">Add more</a>
    <br />
    <div id="notification" style="display:none; padding: 10px;">
        @if (TempData["msg"] != null)
        {
            <div class="mb-3 alert alert-info">
                @TempData["msg"]
            </div>
        }
    </div>
</div>
<style>
    /* Search bar styling */
    .input-group {
        max-width: 300px; /* Set a max width for the search bar */
        margin-bottom: 20px; /* Add margin below the search bar */
    }

    /* Highlight row on hover */
    .table tbody tr:hover {
        background-color: #f1f1f1; /* Light gray background */
    }

    /* Optional: Make the table more visually appealing */
    .table {
        margin-top: 20px;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Show notification if it exists
            if ($('#notification').text().trim() !== '') {
                $('#notification').fadeIn().delay(3000).fadeOut(); // Display for 3 seconds
            }
        });
    </script>
}