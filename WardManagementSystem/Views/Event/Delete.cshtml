@model WardDapperMVC.Model.Domain.VisitSchedule

@{
    ViewBag.Title = "Delete Event";
}

<h2>@ViewBag.Title</h2>

<div>
    <h4>Are you sure you want to delete this event?</h4>
    <div>
        <h3>@Model.VisitType</h3>
        <p><strong>Date:</strong> @Model.Date</p>
        <p><strong>Doctor ID:</strong> @Model.DoctorID</p>
        <p><strong>Patient ID:</strong> @Model.PatientID</p>
        <p><strong>Inactive:</strong> @Model.InActive</p>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.ScheduleID)
        <div class="form-group">
            <input type="submit" value="Delete" class="btn btn-danger" />
            @Html.ActionLink("Back to List", "Index", new { @class = "btn btn-secondary" })
        </div>
    }
</div>
