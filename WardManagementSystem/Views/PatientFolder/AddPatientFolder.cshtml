@model WardDapperMVC.Models.Domain.PatientFolder
@{
    ViewData["Title"] = "Add Patient Folder";
}

<div class="wide-dark-box">
    <h2 class="text-center">OPEN PATIENT FOLDERS</h2>
    <br />
    <p>
        Welcome to the Add Patient Folders section of our Ward Management System,
        where you can search for patients by number and assign them to beds within a ward.
    </p>

    <div class="col-md-4">
        <label asp-for="PatientNumber" class="form-label">Patient Number<span class="text-danger">*</span></label>
        <div class="d-flex align-items-center">
            <input asp-for="PatientNumber" type="text" class="form-control me-2" placeholder="Enter Patient Number" style="flex: 1;" />
            <button type="button" class="btn btn-info" onclick="searchPatient()">Search</button>
        </div>
       @*  <span class="text-danger" asp-validation-for="PatientNumber"></span> *@
    </div>
    <br />
    <form id="patientForm" asp-action="AddPatientFolder" method="post">
        <input type="hidden" asp-for="PatientId" readonly />

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="FirstName" class="form-label">First Name<span style="color: red;">*</span></label>
                <input asp-for="FirstName" type="text" class="form-control" readonly />
            </div>

            <div class="col-md-4">
                <label asp-for="LastName" class="form-label">Last Name<span style="color: red;">*</span></label>
                <input asp-for="LastName" type="text" class="form-control" readonly />
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="WardId" class="form-label">Ward Name<span style="color: red;">*</span></label>
                @Html.DropDownListFor(model => model.WardId, (SelectList)ViewBag.WardList, "Select Ward", new { @class = "form-control", id = "WardDropdown" })
                <span class="text-danger" asp-validation-for="WardId"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="BedID" class="form-label">Bed Number<span style="color: red;">*</span></label>
                @Html.DropDownListFor(model => model.BedID, new SelectList(new List<SelectListItem>(), "Value", "Text"), "Select Bed", new { @class = "form-control", id = "BedDropdown" })
                <span class="text-danger" asp-validation-for="BedID"></span>
            </div>   
        </div>
        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="AdmitDate" class="form-label">Admit Date<span style="color: red;">*</span></label>
                <input asp-for="AdmitDate" type="date" class="form-control" />
                <span class="text-danger" asp-validation-for="AdmitDate"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Status" class="form-label">Status<span style="color: red;">*</span></label>
                <select asp-for="Status" class="form-control">
                    <option value="">Select Status</option>
                    <option value="Admitted">Admitted</option>
                    @* <option value="Discharge">Discharge</option> *@
                </select>
                <span class="text-danger" asp-validation-for="Status"></span>
            </div>
        </div>
        
        <br />
        @if (TempData["msg"] != null)
        {
            <div id="notification" class="mb-3 alert alert-info">
                @TempData["msg"]
            </div>
        }

        <div class="d-flex justify-content-start align-items-center">
            <button type="submit" class="btn btn-success">Save</button>
            <span class="mx-2" style="border-right: 2px solid white; height: 24px;"></span>
            <a asp-controller="PatientFolder" asp-action="DisplayAllPatientFolder" class="my-2 btn btn-primary">Display Records</a>
        </div>

    </form>
</div>

@* This is JS for Searching using PatientNumber *@
@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
         let previousBedID = null;  // Initialize previousBedID as null

        function searchPatient() {
            var patientNumber = $('#PatientNumber').val().trim();
            // Validate the format (assuming valid format starts with "PAT" and is followed by digits)
            var regex = /^PAT\d+$/; // Matches "PAT" followed by one or more digits

            if (patientNumber && regex.test(patientNumber)) {
                $.ajax({
                    url: '@Url.Action("GetPatientByNumber", "PatientFolder")',
                    type: 'GET',
                    data: { patientNumber: patientNumber },
                    success: function (data) {
                        if (data) {
                            $('#FirstName').val(data.firstName);
                            $('#LastName').val(data.lastName);
                            $('#PatientId').val(data.patientID);
                        } else {
                            alert('Patient not found');
                        }
                    },
                    error: function () {
                        alert('Error retrieving patient information');
                    }
                });
            } else {
                alert('Please enter a valid Patient Number (e.g., PAT01,PAT100)');
            }
        }


        $('#WardDropdown').change(function () {
            var wardId = $(this).val();
            if (wardId) {
                $.ajax({
                    url: '@Url.Action("GetBedsByWard", "PatientFolder")',
                    type: 'GET',
                    data: { wardId: wardId },
                    success: function (data) {
                        var bedDropdown = $('#BedDropdown');
                        bedDropdown.empty();
                        bedDropdown.append('<option value="">Select Bed</option>');
                        $.each(data, function (i, bed) {
                            bedDropdown.append('<option value="' + bed.value + '">' + bed.text + '</option>');
                        });
                    },
                    error: function () {
                        alert('Error retrieving beds');
                    }
                });
            } else {
                $('#BedDropdown').empty().append('<option value="">Select Bed</option>');
            }
        });

        $('#BedDropdown').change(function () {
            var selectedBedID = $(this).val();
            if (selectedBedID) {
                if (previousBedID && previousBedID !== selectedBedID) {
                    $.ajax({
                        url: '@Url.Action("UpdateBedAvailability", "PatientFolder")',
                        type: 'POST',
                        data: {
                            newBedID: selectedBedID,
                            previousBedID: previousBedID
                        },
                        success: function () {
                            previousBedID = selectedBedID;  // Update previousBedID after successful update
                        },
                        error: function () {
                            alert('Error updating bed availability');
                        }
                    });
                } else {
                    previousBedID = selectedBedID;  // Update previousBedID if no previous bed
                }
            }
        });

        $(document).ready(function () {
            // Hide validation messages when user starts typing
            $('input, textarea').on('input', function () {
                $(this).siblings('.text-danger').hide();
            });
        });
        $(document).ready(function () {
            // Show notification if it exists
            if ($('#notification').text().trim() !== '') {
                $('#notification').fadeIn().delay(3000).fadeOut(); // Display for 3 seconds
            }
        });

    </script>
}